{
  "name": "language-exchange-platform",
  "version": "1.0.0",
  "description": "A comprehensive language exchange platform connecting language learners worldwide through real-time chat and video calls",
  "main": "index.js",
  "scripts": {
    "build": "npm install --prefix backend && npm install --prefix frontend && npm run build --prefix frontend",
    "start": "npm run start --prefix backend",
    "dev": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules frontend/dist",
    "lint": "npm run lint --prefix frontend",
    "test": "npm test --prefix backend && npm test --prefix frontend",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md}\""
  },
  "keywords": [
    "language-exchange",
    "language-learning",
    "chat",
    "video-call",
    "real-time",
    "react",
    "nodejs",
    "mongodb",
    "stream-io",
    "education",
    "social-platform"
  ],
  "author": "Group 17 INSA Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/letera1/Group-17-Insa-Team-Project.git"
  },
  "bugs": {
    "url": "https://github.com/letera1/Group-17-Insa-Team-Project/issues"
  },
  "homepage": "https://github.com/letera1/Group-17-Insa-Team-Project#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "prettier": "^3.2.5"
  }
}
